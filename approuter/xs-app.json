{
    "welcomeFile": "index.html",
    "routes":[
        {
            "source": "/user-api/currentUser$",
            "target": "/currentUser",
            "service": "sap-approuter-userapi"
        },
        {
            "source": "^/api/applications/(.*)$",
            "target": "/$1",
            "destination": "srvProntosPagosNode"
        },
        {
            "source": "^/doc",
            "target": "/doc/",
            "destination": "prontosPagosService"
        },
        {
            "source": "/index.html",
            "target": "/index.html",
            "localDir": "webapp"
        }
    ]
}