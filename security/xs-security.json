{
    "xsappname": "cotemar-prontospagos-xsuaa",
    "tenant-mode": "dedicated",
    "oauth2-configuration": {
      "redirect-uris": [
        "http://localhost:5000/login/callback",
        "https://*.hana.ondemand.com/**",
        "https://oauth.pstmn.io/v1/callback"
      ]
    },
    "scopes": [
      {
        "name": "$XSAPPNAME.Viewer",
        "description": "Viewer"
      }
    ],
    "role-templates": [
      {
        "name": "Viewer",
        "description": "Viewer",
        "scope-references": [
          "$XSAPPNAME.Viewer"
        ]
      }
    ],
    "role-collections": [
      {
        "name": "prontospagos-viewer",
        "description": "Prontos pagos viewer",
        "role-template-references": [
          "$XSAPPNAME.Viewer"
        ]
      }
    ]
}